# =============================================================================
# MONEY GENERATOR APP - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# =============================================================================

# =============================================================================
# ADMIN & STATIC TOKEN AUTHENTICATION
# =============================================================================
# SECURITY: These MUST be changed from defaults before going to production.
# The default values are publicly known and grant admin access if left unchanged.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Static admin token — used by requireAdmin middleware and ops endpoints
AUTH_ADMIN_TOKEN=REPLACE_WITH_LONG_RANDOM_STRING

# Static user token — legacy fallback auth; rotate in production
AUTH_USER_TOKEN=REPLACE_WITH_DIFFERENT_LONG_RANDOM_STRING

# =============================================================================
# STRIPE CONFIGURATION
# =============================================================================
# Get your keys from: https://dashboard.stripe.com/apikeys

# Secret key for server-side API calls (starts with sk_live_ or sk_test_)
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_SECRET_KEY

# Publishable key for client-side Stripe.js (starts with pk_live_ or pk_test_)
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_PUBLISHABLE_KEY

# Webhook secret for payment webhooks (starts with whsec_)
# Get this from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_WEBHOOK_SECRET

# =============================================================================
# STRIPE PRICE IDS
# =============================================================================
# Create products in Stripe Dashboard: https://dashboard.stripe.com/products
# Then copy the Price IDs here (start with price_)

# Pro Plan: $14.99/month or $119.88/year
STRIPE_PRICE_PRO_MONTHLY=price_REPLACE_WITH_PRO_MONTHLY_PRICE_ID
STRIPE_PRICE_PRO_ANNUAL=price_REPLACE_WITH_PRO_ANNUAL_PRICE_ID

# Enterprise Plan: $49.99/month or $479.88/year
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_REPLACE_WITH_ENTERPRISE_MONTHLY_PRICE_ID
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_REPLACE_WITH_ENTERPRISE_ANNUAL_PRICE_ID

# =============================================================================
# STRIPE CONNECT CONFIGURATION
# =============================================================================
# For marketplace/platform functionality with connected accounts

# Webhook secret for V2 account events (thin events)
# Create a webhook endpoint with:
#   - Events from: Connected accounts
#   - Payload style: Thin
#   - Events: v2.core.account[requirements].updated, etc.
# For local dev: stripe listen --thin-events '...' --forward-thin-to http://localhost:4000/api/connect/webhooks/accounts
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_REPLACE_WITH_CONNECT_WEBHOOK_SECRET

# Webhook secret for subscription events (standard events)
# Create a webhook endpoint with:
#   - Events from: Account
#   - Events: customer.subscription.*, invoice.*, etc.
# For local dev: stripe listen --forward-to http://localhost:4000/api/connect/webhooks/subscriptions
STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=whsec_REPLACE_WITH_SUBSCRIPTION_WEBHOOK_SECRET

# Platform subscription price ID
# Create a subscription product for connected accounts to subscribe to your platform
# This enables premium features for sellers
STRIPE_CONNECT_PLATFORM_PRICE_ID=price_REPLACE_WITH_PLATFORM_SUBSCRIPTION_PRICE_ID

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Port for the backend server
# Railway commonly uses PORT; local scripts may still read BACKEND_PORT.
PORT=4000
BACKEND_PORT=4000

# Environment: development, staging, production
NODE_ENV=development

# Frontend URL for redirects (CORS, OAuth callbacks, email links)
# Production value: https://moneygenerator.app
FRONTEND_URL=http://localhost:3000

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================

# Secret key for signing JWT tokens (use a long random string in production!)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# JWT token expiration (examples: 1h, 24h, 7d)
JWT_EXPIRES_IN=7d

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection settings

# Full connection URL (alternative to individual settings below)
DATABASE_URL=postgresql://moneygen:moneygen_secret@localhost:5432/moneygenerator

# Individual connection settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=moneygenerator
DB_USER=moneygen
DB_PASSWORD=moneygen_secret
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# =============================================================================
# OPTIONAL: THIRD-PARTY INTEGRATIONS
# =============================================================================

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Webhook signature secret — MUST be set; default is publicly known and accepts forged events
PAYPAL_WEBHOOK_SECRET=REPLACE_WITH_PAYPAL_WEBHOOK_SECRET

# Plaid (for bank connections)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Webhook signature secret — MUST be set; default is publicly known and accepts forged events
PLAID_WEBHOOK_SECRET=REPLACE_WITH_PLAID_WEBHOOK_SECRET

# CRM webhook secret — MUST be set; default is publicly known
CRM_WEBHOOK_SECRET=REPLACE_WITH_CRM_WEBHOOK_SECRET

# Redis (for caching - optional)
REDIS_URL=redis://localhost:6379

# =============================================================================
# CORS & APPLICATION URL
# =============================================================================

# Allowed CORS origin
# Development value: http://localhost:3000
# Production value: https://moneygenerator.app
CORS_ORIGIN=http://localhost:3000

# Base URL used for referral links and billing portal fallback
# Development value: http://localhost:3000
# Production value: https://moneygenerator.app
# NOTE: code reads APP_URL (not APP_BASE_URL)
APP_URL=http://localhost:3000

# Stripe billing portal fallback URL (if not using Stripe-hosted portal)
STRIPE_PORTAL_URL=

# =============================================================================
# OBJECT STORAGE (optional — defaults to local disk, lost on container restart)
# =============================================================================
# Provider: local | s3 | r2 | gcs
OBJECT_STORAGE_PROVIDER=local
OBJECT_STORAGE_BUCKET=moneygenerator-assets
OBJECT_STORAGE_PUBLIC_BASE_URL=
# SECURITY: default is publicly known — must be rotated in production
OBJECT_STORAGE_SIGNING_SECRET=REPLACE_WITH_RANDOM_SIGNING_SECRET
ASSET_TEMP_RETENTION_HOURS=24
