# Production Environment Variables
NODE_ENV=production
BACKEND_PORT=4000

# PayPal Configuration
PAYPAL_CLIENT_ID=<your-production-paypal-client-id>
PAYPAL_CLIENT_SECRET=<your-production-paypal-client-secret>
PAYPAL_WEBHOOK_SECRET=<your-production-paypal-webhook-secret>

# Plaid Configuration
PLAID_CLIENT_ID=<your-production-plaid-client-id>
PLAID_SECRET=<your-production-plaid-secret>
PLAID_WEBHOOK_SECRET=<your-production-plaid-webhook-secret>
PLAID_ENV=production

# CRM Integration
CRM_WEBHOOK_SECRET=<generate-random-secret>

# Authentication Tokens (Generate secure random tokens)
AUTH_USER_TOKEN=<generate-secure-user-token>
AUTH_ADMIN_TOKEN=<generate-secure-admin-token>

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
WEBHOOK_RATE_LIMIT_MAX=60
WEBHOOK_REPLAY_WINDOW_MS=300000

# Application URL
APP_BASE_URL=https://your-backend-domain.com

# CORS Settings
CORS_ORIGIN=https://your-frontend-domain.netlify.app
