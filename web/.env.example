# ============================================
# Web App Environment Variables
# ============================================

# Backend API Configuration
# For LOCAL DEVELOPMENT: Leave EMPTY to use Vite proxy (recommended)
# The Vite dev server proxies /api/* and /auth/* to http://localhost:4000
# For PRODUCTION: Set to your API URL (e.g., https://api.moneygenerator.app)
VITE_API_URL=

# API Request Timeout (ms)
VITE_API_TIMEOUT=30000

# Feature Flags
VITE_V2_ENABLED=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_PLAID=true
VITE_ENABLE_REFERRALS=true
VITE_ENABLE_SUBSCRIPTIONS=true

# Third-Party Integrations
# Plaid: sandbox | development | production
VITE_PLAID_ENV=sandbox

# Analytics (PostHog)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# Application Info
VITE_APP_NAME=Money Generator
VITE_APP_VERSION=1.3.0

# Build Information (auto-populated)
VITE_BUILD_TIME=
VITE_GIT_COMMIT=
VITE_GIT_BRANCH=

# ============================================
# Netlify-Specific Variables
# ============================================
# Set these in Netlify Dashboard → Site settings → Environment variables

# Production (context: production)
# VITE_API_URL=https://api.moneygenerator.app
# VITE_PLAID_ENV=production

# Preview/Staging (context: deploy-preview)
# VITE_API_URL=https://staging-api.moneygenerator.app
# VITE_PLAID_ENV=sandbox

